{
  "name": "payment-guard",
  "version": "0.1.0",
  "description": "Open-source, non-custodial payment safety layer for AI agents. The guardrail between your AI and your wallet.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "payment-guard": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "THREAT_MODEL.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "keywords": [
    "ai",
    "agent",
    "payments",
    "security",
    "mcp",
    "guardrails",
    "open-source"
  ],
  "author": "Divyansh Tiwari (https://github.com/DivyanshTiwari20)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DivyanshTiwari20/payment-guard.git"
  },
  "homepage": "https://github.com/DivyanshTiwari20/payment-guard#readme",
  "bugs": {
    "url": "https://github.com/DivyanshTiwari20/payment-guard/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
